<%- include('../layouts/start.ejs') %>
<link rel="stylesheet" href="/Css/main.css">
<link rel="stylesheet" href="/Css/responsive.css">
<script src="/js/main.js" defer></script>
</head>

<body>
  <!-- Success -->
  <div id="successModal" class="success-modal hidden">
  <div class="success-box">

    <div class="face-happy">
      <div class="eye"></div>
      <div class="eye right"></div>
      <div class="mouth happy"></div>
    </div>

    <h2>Order Successful!</h2>
    <p>Your order has been placed.</p>

    <button id="successBtn" class="btn main_btn">Go Home</button>
  </div>
</div>
<div class="container">
<%- include('../layouts/navigation.ejs') %>

<main class="flex" style="flex-direction: column; gap: 20px;">
<div class="checkout-wrapper">
<h1 class="checkout-title">Checkout</h1>

<!--Product -->
<div class="checkout-card">
  <div class="checkout-summary">
    <% let total = 0; %>

    <% prods.forEach(p => { 
      total += p.productId.price * p.quantity;
    }) %>

    <p>Total Items: <%= prods.length %></p>
    <h2>Total Price: $<%= total.toFixed(2) %></h2>
  </div>
</div>

<div id="cardDetails" class="card-details hidden">
  <label>Card Number</label>
  <input type="text" placeholder="1234 5678 9012 3456" maxlength="19">

  <div class="card-row">
    <div>
      <label>Expiry</label>
      <input type="text" placeholder="MM/YY" maxlength="5">
    </div>

    <div>
      <label>CVV</label>
      <input type="text" placeholder="123" maxlength="3">
    </div>
  </div>
</div>

<!-- <form action="/create-order" method="POST" class="checkout-form"> With controller and payment methood -->
  <form id="checkoutForm" class="checkout-form">
  
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <label>Name</label>
  <input type="text" name="name" required>

  <label>Address</label>
  <input type="text" name="address" required>

  <label>Payment Method</label>
  <select name="payment" style="background: #3f3e3e85 !important;" id="paymentMethod">
    <option value="cod" >Cash on Delivery</option>
    <option value="card">Card </option>
  </select>

  <button class="btn main_btn" type="submit">Place Order</button>
</form>
</div>
</main>

 <%- include('../layouts/end.ejs') %>